function renderVisual(key: string) {
  switch (key) {
    case "regions":
      return <GlobeVisual />;
    case "free-year":
      return <FreeYearVisual />;
    case "nira":
      return <NiraVisual />;
    case "defense":
      return <DefenseVisual />;
    case "backups":
      return <BackupsVisual />;
    case "monitoring":
      return <MonitoringVisual />;
    case "support":
      return <SupportVisual />;
    default:
      return null;
  }
}

export function Differentiators() {
  const [activeId, setActiveId] = useState(differentiators[0]?.id ?? "");
  const [displayId, setDisplayId] = useState(activeId);
  const [previousId, setPreviousId] = useState<string | null>(null);
  const [reduceMotion, setReduceMotion] = useState(false);

  useEffect(() => {
    if (typeof window === "undefined") return;
    const media = window.matchMedia("(prefers-reduced-motion: reduce)");
    const sync = () => setReduceMotion(media.matches);
    sync();
    media.addEventListener("change", sync);
    return () => media.removeEventListener("change", sync);
  }, []);

  useEffect(() => {
    if (!activeId || activeId === displayId) return;
    if (reduceMotion) {
      setDisplayId(activeId);
      setPreviousId(null);
      return;
    }

    setPreviousId(displayId);
    setDisplayId(activeId);
    const timer = window.setTimeout(() => setPreviousId(null), VISUAL_FADE_MS);
    return () => window.clearTimeout(timer);
  }, [activeId, displayId, reduceMotion]);

  const activeItem = differentiators.find((item) => item.id === displayId) ?? differentiators[0];
  const previousItem = previousId ? differentiators.find((item) => item.id === previousId) : null;

  return (
    <section className="diff-section homepage-section" id="why">
      <div className="shell">
        <SectionHeader
          eyebrow="WHY ONENET SERVERS"
          title="Reasons founders choose us."
          lead="Over 10 years of delivering excellence - our commitments to your success speaks for us."
          centered
        />

        <div className="diff-accordion">
          <div className="diff-accordion__visual-wrap">
            <div className="diff-accordion__visual-frame" role="img" aria-label={activeItem.visualLabel}>
              {previousItem && !reduceMotion ? (
                <div className="diff-accordion__visual-layer diff-accordion__visual-layer--out" aria-hidden="true">
                  {renderVisual(previousItem.visualKey)}
                </div>
              ) : null}
              <div className="diff-accordion__visual-layer diff-accordion__visual-layer--in" key={displayId}>
                {renderVisual(activeItem.visualKey)}
              </div>
            </div>
          </div>

          <div className="diff-accordion__list">
            {differentiators.map((item) => {
              const isActive = item.id === activeId;
              const triggerId = `diff-trigger-${item.id}`;
              const panelId = `diff-panel-${item.id}`;
              return (
                <article key={item.id} className={`diff-accordion__item${isActive ? " is-active" : ""}`}>
                  <h3 className="diff-accordion__heading">
                    <button
                      type="button"
                      id={triggerId}
                      className="diff-accordion__trigger"
                      aria-expanded={isActive}
                      aria-controls={panelId}
                      onClick={() => {
                        if (!isActive) setActiveId(item.id);
                      }}
                    >
                      <span className="diff-accordion__headline">{item.headline}</span>
                      <span className="diff-accordion__chevron" aria-hidden="true">
                        <ChevronIcon />
                      </span>
                    </button>
                  </h3>
                  <div
                    id={panelId}
                    className="diff-accordion__panel"
                    role="region"
                    aria-labelledby={triggerId}
                    aria-hidden={!isActive}
                  >
                    <div className="diff-accordion__panel-inner">
                      <p className="diff-accordion__body">{item.body}</p>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  );
}
